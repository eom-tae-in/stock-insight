# StockInsight 환경 설정 (Phase 6: Supabase 단일 기반)

# 실행 환경 (development, production, test)
NODE_ENV=development

# Supabase 프로젝트 URL (필수)
# https://supabase.com에서 프로젝트 생성 후 프로젝트 설정에서 확인할 수 있습니다
# 형식: https://YOUR_PROJECT_ID.supabase.co
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase 공개 API 키 (필수)
# Supabase Dashboard의 Settings → API에서 "anon public" 키를 복사합니다
# 이 키는 공개되어도 안전합니다 (행 수준 보안 RLS 설정 필요)
SUPABASE_KEY=your_supabase_anon_key_here

# 클라이언트에서 접근하는 Supabase URL (필수)
# 서버/클라이언트 모두에서 사용되며, NEXT_PUBLIC_ 접두사로 클라이언트에 노출됨
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# 클라이언트에서 접근하는 Supabase anon key (필수)
# OAuth 및 클라이언트 인증에 필요하며, NEXT_PUBLIC_ 접두사로 클라이언트에 노출됨
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
