# StockInsight 환경 설정

# Finnhub API 키 (선택 사항)
# https://finnhub.io에서 발급받은 API 키
# 없으면 로컬 데모 데이터를 사용합니다
# 로컬 개발 환경에서만 사용하며, 공개 저장소에 실제 키를 업로드하면 안됨
FINNHUB_API_KEY=your_finnhub_api_key_here

# 실행 환경 (development, production, test)
# 기본값: development
NODE_ENV=development

# ============================================================================
# Supabase 마이그레이션 설정 (Phase 1: 환경 준비)
# ============================================================================
# SQLite에서 Supabase(PostgreSQL)로 점진적 마이그레이션 중입니다.
# 진행 상황:
#   Phase 1: 환경 설정 및 Adapter 구조화 (현재 단계)
#   Phase 2: 첫 번째 테이블 마이그레이션 (searches)
#   Phase 3: 이중 쓰기 및 데이터 동기화
#   Phase 4: Supabase Primary 전환
#   Phase 5: 남은 테이블 마이그레이션
#   Phase 6: SQLite 완전 제거

# DB 제공자 선택 (레거시 설정, Phase 6에서 폐기 예정)
# true: Supabase(PostgreSQL) 사용 (Phase 2+에서만 true로 설정하세요)
# false: SQLite 사용 (기본값, Phase 1에서 권장)
# 주의: USE_SUPABASE=true일 때는 SUPABASE_URL과 SUPABASE_KEY가 필수입니다.
USE_SUPABASE=false

# 데이터베이스 읽기 모드 (Phase 4+: Supabase Primary 전환용)
# sqlite: SQLite에서만 읽기 (기본값)
# supabase: Supabase에서 읽기 (실패 시 SQLite로 자동 폴백)
# 주의: supabase 모드일 때는 SUPABASE_URL과 SUPABASE_KEY가 필수입니다.
DB_READ_MODE=sqlite

# 데이터베이스 쓰기 모드 (Phase 4+: Supabase Primary 전환용)
# sqlite: SQLite에만 쓰기 (기본값)
# supabase: Supabase에만 쓰기 (실패 시 에러, 폴백 없음)
# 주의: supabase 모드일 때는 SUPABASE_URL과 SUPABASE_KEY가 필수입니다.
DB_WRITE_MODE=sqlite

# Supabase 프로젝트 URL (USE_SUPABASE=true일 때만 필요)
# https://supabase.com에서 프로젝트 생성 후 프로젝트 설정에서 확인할 수 있습니다.
# 형식: https://YOUR_PROJECT_ID.supabase.co
# 예: https://abc123def456.supabase.co
# 주의: 이 값이 없으면 USE_SUPABASE=true 시 앱 시작이 실패합니다.
# SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Supabase 공개 API 키 (anon 키, USE_SUPABASE=true일 때만 필요)
# Supabase Dashboard의 Settings → API에서 "anon public" 키를 복사합니다.
# 이 키는 공개되어도 안전합니다 (행 수준 보안 RLS 설정 필요).
# 주의: 이 값이 없으면 USE_SUPABASE=true 시 앱 시작이 실패합니다.
# SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
